{
  "name": "trello-api-automation",
  "version": "1.0.0",
  "description": "Trello API Automation using Postman, Newman and Jenkins",
  "author": "Himanshu Sharma",
  "license": "ISC",
  "scripts": {
    "test": "newman run Collections/Trello_hindi.postman_collection.json -e Environments/Stg_Trello_Hindi.postman_environment.json",
    "report": "newman run Collections/Trello_hindi.postman_collection.json -e Environments/Stg_Trello_Hindi.postman_environment.json -r cli,htmlextra --reporter-htmlextra-export Reports/report.html"
  },
  "devDependencies": {
    "newman": "^6.2.1",
    "newman-reporter-htmlextra": "^1.23.1"
  }
}